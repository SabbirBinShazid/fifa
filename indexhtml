<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Minimal IPTV Stream Player</title>
  
  <!-- Tailwind CSS Play CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  
  <!-- HLS.js for full cross-browser live stream support -->
  <script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
  
  <!-- Lucide Icons -->
  <script src="https://unpkg.com/lucide@latest"></script>

  <style>
    /* Custom style slider for the volume picker */
    input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance: none;
      appearance: none;
      width: 12px;
      height: 12px;
      border-radius: 50%;
      background: #ef4444;
      cursor: pointer;
      box-shadow: 0 0 6px rgba(239, 68, 68, 0.6);
      transition: transform 0.1s ease-in-out;
    }
    input[type="range"]::-webkit-slider-thumb:hover {
      transform: scale(1.25);
    }
  </style>
</head>
<body class="bg-black text-zinc-100 font-sans min-h-screen flex flex-col items-center justify-center p-4 md:p-8 relative overflow-hidden bg-[radial-gradient(circle_at_50%_50%,#0a0a0c_0%,#000000_100%)]">

  <!-- Aesthetic Ambient Background Glow -->
  <div class="absolute inset-0 bg-gradient-to-b from-zinc-950/20 via-black to-zinc-950/20 pointer-events-none"></div>
  <div class="absolute top-1/4 left-1/4 w-[350px] h-[350px] bg-red-600/5 blur-[100px] rounded-full pointer-events-none animate-pulse"></div>
  <div class="absolute bottom-1/4 right-1/4 w-[350px] h-[350px] bg-zinc-800/10 blur-[100px] rounded-full pointer-events-none"></div>

  <!-- Header Section with Live Status Badge -->
  <header class="w-full max-w-5xl flex flex-col items-center justify-center text-center gap-1.5 mb-6 z-10 select-none">
    <div class="flex items-center gap-2">
      <div class="relative flex items-center justify-center">
        <span class="w-2 h-2 rounded-full bg-red-500 animate-ping absolute block"></span>
        <span class="w-2 h-2 rounded-full bg-red-600 relative block border border-black/80"></span>
      </div>
      <h1 class="text-xs font-black tracking-[0.3em] text-white/50 uppercase">
        LIVE BROADCAST FEED
      </h1>
    </div>
    <p id="active-stream-title" class="text-[11px] font-mono tracking-wider text-zinc-400 max-w-xl truncate px-4">
      Loading Broadcast...
    </p>
  </header>

  <!-- Player Aspect-Video Display Card -->
  <div id="iptv-player-container" class="relative w-full max-w-5xl aspect-video sm:rounded-2xl border border-white/5 bg-black overflow-hidden shadow-2xl shadow-black/80 flex items-center justify-center z-10 group">
    
    <!-- Video Element Canvas -->
    <div id="viewport-wrapper" class="w-full h-full flex items-center justify-center transition-all duration-300 origin-center bg-black">
      <video 
        id="video-player" 
        class="w-full h-full object-contain pointer-events-none"
        playsinline
        preload="auto"
      ></video>
    </div>

    <!-- Central Buffering / Loading Indicator Spinner -->
    <div id="loader-hud" class="absolute inset-0 flex items-center justify-center bg-black/60 backdrop-blur-md hidden pointer-events-none transition-all">
      <div class="p-5 rounded-full bg-black/60 border border-white/10 flex items-center justify-center">
        <i data-lucide="refresh-cw" class="text-red-500 animate-spin w-8 h-8"></i>
      </div>
    </div>

    <!-- Error State Overlay Indicator -->
    <div id="error-hud" class="absolute inset-x-4 inset-y-4 md:inset-x-0 md:inset-y-0 rounded-xl bg-zinc-950/95 backdrop-blur-xl border border-red-500/25 flex flex-col items-center justify-center gap-3.5 text-center hidden z-30">
      <div class="w-12 h-12 bg-red-500/10 border border-red-500/20 text-red-500 rounded-full flex items-center justify-center shadow-lg shadow-red-500/5">
        <i data-lucide="alert-triangle" class="w-6 h-6"></i>
      </div>
      <div class="flex flex-col gap-1 px-4">
        <p class="text-sm font-semibold tracking-wide text-white">Stream Failed to Connect</p>
        <p id="error-message-text" class="text-xs text-zinc-400 leading-relaxed max-w-sm ml-auto mr-auto">
          The stream link may be expired, geo-blocked, or requires fresh server configuration credentials.
        </p>
      </div>
      <button id="btn-error-retry" class="mt-1 px-4 py-2 bg-red-600 hover:bg-red-500 text-white rounded-xl text-xs font-semibold flex items-center gap-2 transition-all cursor-pointer shadow-xl shadow-red-600/20 active:scale-95">
        <i data-lucide="refresh-cw" class="w-3.5 h-3.5"></i>
        Retry Live Connection
      </button>
    </div>

    <!-- Custom Control Layer -->
    <div id="controls-panel" class="absolute inset-0 flex flex-col justify-between z-10 transition-opacity duration-300 opacity-100">
      
      <!-- Top URL / Status Bar HUD -->
       <!-- <div class="w-full flex items-start justify-between p-4 sm:p-6 bg-gradient-to-b from-black/90 to-transparent pointer-events-auto">
        <div class="flex flex-col gap-1 select-none bg-black/40 backdrop-blur-md px-3 py-2 rounded-xl border border-white/5 max-w-[200px] sm:max-w-xs md:max-w-md">
          <span class="text-[8px] uppercase tracking-[0.25em] text-zinc-500 font-extrabold leading-none">Source URL</span>
          <span id="active-stream-url" class="text-[10px] font-mono text-zinc-300 font-medium truncate block select-all"></span>
        </div>
        
        <div id="connection-status-badge" class="flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-[10px] font-mono border backdrop-blur-md bg-emerald-500/10 border-emerald-500/20 text-emerald-400">
          <i id="badge-activity-icon" data-lucide="activity" class="w-3.5 h-3.5"></i>
          <span id="badge-status-text" class="capitalize font-bold tracking-wider">Playable</span>
        </div>
      </div>   -->

      <!-- Play Overlay Central Toggle -->
      <div id="play-overlay" class="flex-grow flex items-center justify-center p-4 cursor-pointer">
        <div id="play-center-btn" class="relative flex flex-col items-center gap-4 transition-all duration-300 hover:scale-105 active:scale-95">
          <div class="absolute inset-0 bg-red-500/15 blur-[50px] rounded-full scale-150 animate-pulse"></div>
          <div class="w-16 h-16 md:w-20 md:h-20 rounded-full border border-white/10 flex items-center justify-center bg-black/40 backdrop-blur-2xl text-white shadow-2xl hover:border-red-500 hover:text-red-400">
            <i data-lucide="play" class="w-7 h-7 fill-current ml-0.5 text-red-500"></i>
          </div>
        </div>
      </div>

      <!-- Bottom Glass Control Pod Container -->
      <div class="w-full flex flex-col items-center p-6 bg-gradient-to-t from-black/95 via-black/40 to-transparent">
        <div class="flex items-center justify-center gap-2.5 sm:gap-4 md:gap-5 px-6 py-2.5 bg-zinc-950/70 backdrop-blur-2xl rounded-2xl border border-white/10 shadow-2xl">
          
          <!-- Play / Pause Switch -->
          <button id="btn-bottom-play" class="group flex flex-col items-center gap-1 bg-transparent hover:text-white transition-all cursor-pointer">
            <div class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-red-500 hover:bg-white hover:text-black transition-all">
              <i id="btn-play-icon" data-lucide="play" class="w-4 h-4 fill-current"></i>
            </div>
            <span class="text-[8px] uppercase tracking-widest font-bold text-zinc-500 group-hover:text-white">Play</span>
          </button>

          <div class="h-6 w-[1px] bg-white/10"></div>

          <!-- Audio Volume / Mute trigger controls -->
          <div class="flex items-center gap-2" id="volume-control-group">
            <button id="btn-volume-toggle" class="group flex flex-col items-center gap-1 bg-transparent hover:text-white transition-all cursor-pointer">
              <div class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-zinc-300 hover:bg-white hover:text-black transition-all">
                <i id="btn-volume-icon" data-lucide="volume-2" class="w-4 h-4"></i>
              </div>
              <span class="text-[8px] uppercase tracking-widest font-bold text-zinc-500 group-hover:text-white">Mute</span>
            </button>
            <input 
              id="volume-slider" 
              type="range" 
              min="0" 
              max="1" 
              step="0.05" 
              value="1" 
              class="w-14 h-1 bg-zinc-800 rounded-lg cursor-pointer accent-red-600 border border-white/5"
            />
          </div>

          <div class="h-6 w-[1px] bg-white/10"></div>

          <!-- Video Rotation (90 deg increments) -->
          <button id="btn-rotate-view" class="group flex flex-col items-center gap-1 bg-transparent hover:text-white transition-all cursor-pointer" title="Rotate stream view">
            <div class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-zinc-300 hover:bg-white hover:text-black transition-all">
              <i data-lucide="rotate-cw" id="rotate-icon-indicator" class="w-4 h-4 transition-transform"></i>
            </div>
            <span class="text-[8px] uppercase tracking-widest font-bold text-zinc-500 group-hover:text-white">Rotate</span>
          </button>

          <div class="h-6 w-[1px] bg-white/10"></div>

          <!-- Native Fullscreen Mode -->
          <button id="btn-fullscreen" class="group flex flex-col items-center gap-1 bg-transparent hover:text-white transition-all cursor-pointer">
            <div class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-zinc-300 hover:bg-white hover:text-black transition-all">
              <i id="btn-fullscreen-icon" data-lucide="maximize" class="w-4 h-4"></i>
            </div>
            <span class="text-[8px] uppercase tracking-widest font-bold text-zinc-500 group-hover:text-white">Full</span>
          </button>
        </div>
      </div>

    </div>

  </div>

  <footer class="mt-6 text-center text-[9px] tracking-[0.25em] text-zinc-500 uppercase font-medium select-none pointer-events-none">
    <div class="flex items-center justify-center gap-3">
      <span>Double click window for Fullscreen</span>
      <span>•</span>
      <span>Space key to Play / Pause</span>
    </div>
  </footer>

  <script>
    // =========================================================================
    // 1. EDIT YOUR M3U8 STREAM AND LABELS HERE:
    // =========================================================================
    const STREAM_URL = "https://flussonic.defineatoz.com/TSports2/tracks-v1a1/mono.m3u8?remote=120.89.64.93&token=37afae3b8f03ad8a4e5bac9b614629b81850dca8-b3d4062672786f1ceffd57d4d00895d7-1781503852-1781493052";
    const STREAM_TITLE = "T Sports 2 Live Stream Feed";

    // Playback State Configuration
    let hlsInstance = null;
    let rotationAngle = 0;
    let idleTimer = null;

    // Element binding
    const video = document.getElementById('video-player');
    const viewportWrapper = document.getElementById('viewport-wrapper');
    const playerContainer = document.getElementById('iptv-player-container');
    const playOverlay = document.getElementById('play-overlay');
    const loaderHud = document.getElementById('loader-hud');
    const errorHud = document.getElementById('error-hud');
    const errorMessageText = document.getElementById('error-message-text');

    const btnBottomPlay = document.getElementById('btn-bottom-play');
    const btnPlayIcon = document.getElementById('btn-play-icon');
    const badgeStatusText = document.getElementById('badge-status-text');
    const activeStreamTitle = document.getElementById('active-stream-title');
    const activeStreamUrl = document.getElementById('active-stream-url');
    
    const btnVolumeToggle = document.getElementById('btn-volume-toggle');
    const btnVolumeIcon = document.getElementById('btn-volume-icon');
    const volumeSlider = document.getElementById('volume-slider');
    const btnRotateView = document.getElementById('btn-rotate-view');
    const rotateIconIndicator = document.getElementById('rotate-icon-indicator');
    const btnFullscreen = document.getElementById('btn-fullscreen');
    const btnFullscreenIcon = document.getElementById('btn-fullscreen-icon');
    const controlsPanel = document.getElementById('controls-panel');
    const btnErrorRetry = document.getElementById('btn-error-retry');

    // Setup Lucide icons
    lucide.createIcons();

    function updateHUDLabels() {
      activeStreamTitle.textContent = STREAM_TITLE;
      activeStreamUrl.textContent = STREAM_URL;
    }

    // Instantiating standard dynamic HLS buffer connection
    function loadHlsStream(url) {
      if (hlsInstance) {
        hlsInstance.destroy();
        hlsInstance = null;
      }

      errorHud.classList.add('hidden');
      loaderHud.classList.remove('hidden');
      setConnectionStatusBadge('connecting');

      if (Hls.isSupported()) {
        hlsInstance = new Hls({
          maxMaxBufferLength: 8,
          enableWorker: true,
          lowLatencyMode: true,
          backBufferLength: 0
        });

        hlsInstance.loadSource(url);
        hlsInstance.attachMedia(video);

        hlsInstance.on(Hls.Events.MANIFEST_PARSED, function () {
          loaderHud.classList.add('hidden');
          setConnectionStatusBadge('playable');
        });

        hlsInstance.on(Hls.Events.ERROR, function (event, data) {
          if (data.fatal) {
            switch (data.type) {
              case Hls.ErrorTypes.NETWORK_ERROR:
                console.error("Fatal: HLS stream chunks loading network error");
                hlsInstance.startLoad();
                break;
              case Hls.ErrorTypes.MEDIA_ERROR:
                console.error("Fatal: HLS audio/video decoding media error");
                hlsInstance.recoverMediaError();
                break;
              default:
                triggerErrorHUD(data.details || "Connection dropped or blocked");
                break;
            }
          }
        });
      } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
        // Fallback for native Safari
        video.src = url;
        video.addEventListener('loadedmetadata', function() {
          loaderHud.classList.add('hidden');
          setConnectionStatusBadge('playable');
        });
      } else {
        triggerErrorHUD("HLS live streaming is not supported by your current browser.");
      }
    }

    function triggerErrorHUD(detailStr) {
      loaderHud.classList.add('hidden');
      errorHud.classList.remove('hidden');
      setConnectionStatusBadge('failed');
      const hints = detailStr.includes('manifestLoadError') ? 
        "Verify your IP address parameters, tokens, or check CORS firewall rules for streaming." : 
        "Check your network configuration or swap the stream URL in the code.";
      errorMessageText.textContent = `Reason: ${detailStr} (${hints})`;
    }

    function setConnectionStatusBadge(status) {
      const badge = document.getElementById('connection-status-badge');
      if (status === 'playable') {
        badge.className = "flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-[10px] font-mono border backdrop-blur-md bg-emerald-500/10 border-emerald-500/20 text-emerald-400";
        badgeStatusText.textContent = "Live Feed Connected";
      } else if (status === 'connecting') {
        badge.className = "flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-[10px] font-mono border backdrop-blur-md bg-amber-500/10 border-amber-500/20 text-amber-400";
        badgeStatusText.textContent = "Connecting Live";
      } else {
        badge.className = "flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-[10px] font-mono border backdrop-blur-md bg-red-500/10 border-red-500/20 text-red-400";
        badgeStatusText.textContent = "Offline / Interrupted";
      }
    }

    function togglePlay() {
      if (video.paused) {
        video.play().then(() => {
          setIsPlayingState(true);
        }).catch(err => {
          console.warn("Auto-play blocked by host constraints: requires viewport interactive gesture.");
          setIsPlayingState(false);
        });
      } else {
        video.pause();
        setIsPlayingState(false);
      }
    }

    function setIsPlayingState(playing) {
      if (playing) {
        playOverlay.classList.add('hidden');
        btnPlayIcon.setAttribute('data-lucide', 'pause');
        btnBottomPlay.querySelector('span').textContent = "Pause";
      } else {
        playOverlay.classList.remove('hidden');
        btnPlayIcon.setAttribute('data-lucide', 'play');
        btnBottomPlay.querySelector('span').textContent = "Play";
      }
      lucide.createIcons();
    }

    // Hooking up video event handlers
    video.addEventListener('play', () => setIsPlayingState(true));
    video.addEventListener('pause', () => setIsPlayingState(false));
    video.addEventListener('playing', () => loaderHud.classList.add('hidden'));
    video.addEventListener('waiting', () => loaderHud.classList.remove('hidden'));

    playOverlay.addEventListener('click', (e) => {
      e.stopPropagation();
      togglePlay();
    });
    btnBottomPlay.addEventListener('click', togglePlay);
    btnErrorRetry.addEventListener('click', () => {
      loadHlsStream(STREAM_URL);
    });

    // Mute/Volume toggles
    btnVolumeToggle.addEventListener('click', function() {
      video.muted = !video.muted;
      updateVolumeUI();
    });

    volumeSlider.addEventListener('input', function() {
      video.volume = volumeSlider.value;
      if (video.volume > 0) {
        video.muted = false;
      }
      updateVolumeUI();
    });

    function updateVolumeUI() {
      if (video.muted || video.volume === 0) {
        btnVolumeIcon.setAttribute('data-lucide', 'volume-x');
        volumeSlider.value = 0;
      } else {
        btnVolumeIcon.setAttribute('data-lucide', 'volume-2');
        volumeSlider.value = video.volume;
      }
      lucide.createIcons();
    }

    // 90deg video display rotation
    btnRotateView.addEventListener('click', function() {
      rotationAngle = (rotationAngle + 90) % 360;
      viewportWrapper.style.transform = `rotate(${rotationAngle}deg)`;
      rotateIconIndicator.className = `w-4 h-4 transition-transform ${rotationAngle !== 0 ? 'text-red-400 rotate-90' : ''}`;
      
      // Auto-scale correctly in portrait rotational coordinates
      if (rotationAngle === 90 || rotationAngle === 270) {
        viewportWrapper.style.transform += ` scale(0.56)`;
      } else {
        viewportWrapper.style.transform += ` scale(1)`;
      }
    });

    // Fullscreen view toggles
    btnFullscreen.addEventListener('click', toggleFullscreen);
    playerContainer.addEventListener('dblclick', toggleFullscreen);

    function toggleFullscreen() {
      if (!document.fullscreenElement) {
        playerContainer.requestFullscreen().then(() => {
          btnFullscreenIcon.setAttribute('data-lucide', 'minimize');
          lucide.createIcons();
        }).catch(err => {
          console.warn("Fullscreen bounds blocked inside sandboxed iFrame preview mode.");
        });
      } else {
        document.exitFullscreen().then(() => {
          btnFullscreenIcon.setAttribute('data-lucide', 'maximize');
          lucide.createIcons();
        });
      }
    }

    // Hotkey handler (Spacebar pause bounds)
    window.addEventListener('keydown', (e) => {
      if (e.code === 'Space') {
        e.preventDefault();
        togglePlay();
      }
    });

    // Smart Mouse movement Control-panel fading detection
    function resetIdleTimer() {
      controlsPanel.style.opacity = '1';
      clearTimeout(idleTimer);
      if (!video.paused) {
        idleTimer = setTimeout(() => {
          controlsPanel.style.opacity = '0';
        }, 4000);
      }
    }

    playerContainer.addEventListener('mousemove', resetIdleTimer);
    playerContainer.addEventListener('touchstart', resetIdleTimer);

    // Initial load process
    updateHUDLabels();
    loadHlsStream(STREAM_URL);

  </script>
</body>
</html>
